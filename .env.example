# Vercel Environment Variables Template
# Copy this file to .env.local for local development
# Set these variables in your Vercel dashboard for production

# Production API URLs - Replace with your actual backend URLs
NUXT_PUBLIC_API_BASE_URL=https://your-api-backend.vercel.app/api
NUXT_PUBLIC_API_AUTH_URL=https://your-auth-backend.vercel.app/api/auth

# WebSocket URLs for production
NUXT_PUBLIC_WS_MESSAGES_URL=wss://your-messages-backend.vercel.app
NUXT_PUBLIC_WS_PRESENCE_URL=wss://your-presence-backend.vercel.app

# Additional service URLs
NUXT_PUBLIC_GROUP_API_URL=https://your-group-backend.vercel.app/api
NUXT_PUBLIC_NOTIFICATION_API_URL=https://your-notification-backend.vercel.app/api
NUXT_PUBLIC_FILE_SERVICE_URL=https://your-file-backend.vercel.app
NUXT_PUBLIC_PRESENCE_SERVICE_URL=https://your-presence-backend.vercel.app/api

# Environment
NODE_ENV=production

{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".output/public",
  "functions": {
    "server/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/proxy/(.*)",
      "dest": "/api/proxy/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
